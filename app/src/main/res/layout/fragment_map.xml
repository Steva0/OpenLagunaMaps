<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Etichetta versione/build -->
    <TextView
        android:id="@+id/tv_build_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="4dp"
        android:alpha="0.55"
        android:background="#66000000"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textColor="@color/white"
        android:textSize="9sp" />

    <!-- Barra di ricerca (nascosta durante navigazione attiva) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="12dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/open_menu"
                android:padding="14dp"
                android:src="@drawable/ic_hamburger"
                app:tint="@color/black" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Cerca canale o luogo..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="4dp"
                android:textSize="16sp" />

            <ImageButton
                android:id="@+id/btn_search"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Cerca"
                android:src="@android:drawable/ic_menu_search" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Banner GPS disattivato -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_gps_disabled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="96dp"
        android:visibility="gone"
        app:cardBackgroundColor="#CC880000"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp">

        <TextView
            android:id="@+id/tv_gps_disabled_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="GPS disattivato — tocca per attivarlo"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- Lista suggerimenti ricerca rapida -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_places"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="96dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:id="@+id/layout_places_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="4dp" />
    </androidx.cardview.widget.CardView>

    <!-- Schermata "Luoghi salvati" REDESIGN -->
    <LinearLayout
        android:id="@+id/card_saved_places"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@drawable/bg_panel_top_rounded"
        android:layout_marginTop="16dp"
        android:elevation="16dp"
        android:orientation="vertical">

        <!-- Custom Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="I tuoi Luoghi"
                android:textColor="#222222"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_saved_places_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Indietro"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#888888" />
        </RelativeLayout>

        <!-- Filtri in Griglia 2x2 -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp">

            <Button
                android:id="@+id/btn_filter_berth"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="⚓ Posti Barca"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="22dp" />

            <Button
                android:id="@+id/btn_filter_favorite"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="♥ Preferiti"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="22dp" />

            <Button
                android:id="@+id/btn_filter_special"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="🚩 Da visitare"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="22dp" />

            <Button
                android:id="@+id/btn_filter_generic"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="📍 Altro"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="22dp" />
        </GridLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#F0F0F0" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Lista -->
            <ScrollView
                android:id="@+id/scroll_saved_places"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/layout_saved_places_full_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp" />
            </ScrollView>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layout_saved_places_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="64sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Ancora nessun luogo"
                    android:textColor="#222222"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Tieni premuto sulla mappa per salvare un punto o un canale."
                    android:textColor="#888888"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Popup selezione luogo -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_place_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_place_detail_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Punto sulla mappa"
                        android:textColor="#222222"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_place_detail_canal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Canale"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_place_detail_close"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Chiudi"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#444444" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_place_detail_save"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Salva"
                    android:textAllCaps="false"
                    android:textColor="#0091EA"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="#F0F7FF"
                    app:cornerRadius="27dp"
                    app:strokeColor="#0091EA"
                    app:strokeWidth="1dp" />

                <Button
                    android:id="@+id/btn_place_detail_route"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1.2"
                    android:text="Itinerario"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="#0091EA"
                    app:cornerRadius="27dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Pianificazione percorso -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_route_planning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/layout_route_planning_outside_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Header: Titolo e X allineati -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="@string/route_planning_outside_title"
                        android:textColor="#222222"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btn_route_planning_close"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Chiudi"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="#888888" />
                </RelativeLayout>

                <!-- Descrizione a tutta larghezza -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/route_planning_outside_desc"
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:lineSpacingExtra="3dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_route_planning_pick_origin"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/route_planning_pick_origin"
                    android:textAllCaps="true"
                    android:textColor="@color/marine_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:icon="@android:drawable/ic_menu_mylocation"
                    app:iconGravity="textStart"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_route_planning_normal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_route_planning_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- min"
                        android:textColor="#222222"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_route_planning_dist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="-- km"
                        android:textColor="#666666"
                        android:textSize="16sp" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tv_route_destination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Destinazione"
                    android:textColor="#222222"
                    android:textSize="18sp" />

                <!-- Punto di partenza: di default la posizione attuale, ma toccando si può
                     scegliere un punto diverso per vedere solo una stima (vedi
                     startPickingOrigin/setPlanningOrigin in MapFragment.kt). Sfondo a pillola
                     per farla riconoscere come un elemento toccabile, non solo testo. La X
                     compare solo quando l'origine non è quella di default, per tornarci senza
                     dover rifare la ricerca. -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_pill_light_gray"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="4dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:id="@+id/tv_route_origin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:paddingVertical="4dp"
                        android:text="Da: la tua posizione attuale"
                        android:textColor="#0091EA"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btn_route_origin_clear"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="2dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Torna alla posizione attuale"
                        android:padding="6dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:visibility="gone"
                        app:tint="#666666" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_route_planning_cancel"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        android:text="Annulla"
                        android:textAllCaps="false"
                        android:textColor="#666666"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="#F2F2F2"
                        app:cornerRadius="27dp" />

                    <Button
                        android:id="@+id/btn_route_planning_start"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:text="Partenza"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="#0091EA"
                        app:cornerRadius="27dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Banner navigazione attiva -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_nav_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#00695C"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp">

            <ImageView
                android:id="@+id/iv_nav_arrow"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_nav_straight" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_nav_instruction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- m"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_nav_canal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Calcolo..."
                    android:textColor="#B2DFDB"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- HUD: profondita', coordinate, velocita' -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_hud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        app:cardBackgroundColor="#CC003366"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/tv_hud_depth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Canale"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_hud_coords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profondità"
                android:textColor="@color/sea_white"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_hud_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/sea_white"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Chip navigazione attiva: stile Google Maps.
         X per uscire, tempo residuo grande, distanza + orario di arrivo. -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_nav_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="30dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <ImageButton
                android:id="@+id/btn_nav_chip_close"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Esci dalla navigazione"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#444444" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_nav_chip_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- min"
                    android:textColor="#1B5E20"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_nav_chip_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- km · --:--"
                    android:textColor="#666666"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Tachimetro stile Waze: visibile sempre se possibile, o solo in nav. -->
    <it.lagunav.openlagunamaps.ui.SpeedometerView
        android:id="@+id/speedometer"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:visibility="visible" />

    <!-- Altimetro (Profondità) specchiato al tachimetro -->
    <it.lagunav.openlagunamaps.ui.AltitudeView
        android:id="@+id/altitude_view"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:visibility="visible" />


    <!-- Bussola custom: top-right sotto la barra di ricerca.
         Visibile quando la mappa e' ruotata (follow mode o rotazione manuale).
         Tap: esce da follow mode e resetta il nord. La "N" rossa ruota con la mappa. -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_compass"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#CC003366"
        app:cardCornerRadius="45dp"
        app:cardElevation="4dp">

        <!-- PLACEHOLDER_COMPASS_ICON: sostituire con SVG bussola professionale.
             Deve mostrare freccia rossa verso nord + lettera N, sfondo trasparente. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">
            <TextView
                android:id="@+id/tv_compass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#9650;"
                android:textColor="#FF3333"
                android:textSize="26sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- CENTRA: visibile solo quando followMode=false (camera libera).
         Nascosto con GONE quando la camera sta gia' seguendo la barca. -->
    <LinearLayout
        android:id="@+id/layout_centra"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="12dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_recentra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Centra sulla barca"
            android:src="@android:drawable/ic_menu_mylocation"
            app:backgroundTint="#CC003366"
            app:fabSize="mini"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- Schermata "Salva luogo" in stile Bottom Sheet -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_save_place"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Salva punto"
                    android:textColor="#222222"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_save_place_close"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Chiudi"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#444444" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_save_place_invalid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="È stato selezionato un punto fuori dall'area della laguna di Venezia. Selezione non valida."
                android:textColor="#B00020"
                android:textSize="15sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layout_save_place_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/et_save_place_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@null"
                    android:hint="Nome del luogo"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:maxLength="32"
                    android:maxLines="1"
                    android:textColor="#222222"
                    android:textSize="18sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="4dp"
                    android:background="#EEEEEE" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Categoria: "
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_save_place_type_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Luogo"
                        android:textColor="#0091EA"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_type_berth"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="⚓"
                        android:textSize="22sp"
                        app:backgroundTint="#F5F5F5"
                        app:cornerRadius="16dp" />

                    <Button
                        android:id="@+id/btn_type_favorite"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="♥"
                        android:textSize="22sp"
                        app:backgroundTint="#F5F5F5"
                        app:cornerRadius="16dp" />

                    <Button
                        android:id="@+id/btn_type_special"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="🚩"
                        android:textSize="22sp"
                        app:backgroundTint="#F5F5F5"
                        app:cornerRadius="16dp" />

                    <Button
                        android:id="@+id/btn_type_generic"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="📍"
                        android:textSize="22sp"
                        app:backgroundTint="#F5F5F5"
                        app:cornerRadius="16dp" />
                </LinearLayout>

                <EditText
                    android:id="@+id/et_save_place_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_notes_input"
                    android:gravity="top"
                    android:hint="Aggiungi una nota su questo luogo..."
                    android:inputType="textMultiLine"
                    android:maxLength="300"
                    android:maxLines="3"
                    android:minLines="3"
                    android:padding="12dp"
                    android:textColor="#444444"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btn_save_place_delete"
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Elimina"
                        android:src="@android:drawable/ic_menu_delete"
                        android:visibility="gone"
                        app:backgroundTint="#D32F2F"
                        app:elevation="0dp"
                        app:fabCustomSize="54dp"
                        app:maxImageSize="24dp"
                        app:pressedTranslationZ="0dp"
                        app:tint="@color/white" />

                    <Button
                        android:id="@+id/btn_save_place_confirm"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Salva"
                        android:textAllCaps="false"
                        android:textColor="#0091EA"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="#F0F7FF"
                        app:cornerRadius="27dp"
                        app:strokeColor="#0091EA"
                        app:strokeWidth="1dp" />

                    <Button
                        android:id="@+id/btn_save_place_route"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:text="Itinerario"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="#0091EA"
                        app:cornerRadius="27dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
