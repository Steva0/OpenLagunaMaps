<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Barra di ricerca (nascosta durante navigazione attiva) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="12dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Cerca canale o luogo..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/btn_search"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Cerca"
                android:src="@android:drawable/ic_menu_search" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Risultato ricerca -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_search_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="80dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:id="@+id/tv_search_result_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="2"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_navigate_to"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Naviga qui"
                android:textSize="12sp"
                app:backgroundTint="@color/marine_blue" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Banner navigazione attiva -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_nav_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#CC003366"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_nav_instruction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- m"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_nav_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calcolo..."
                    android:textColor="@color/sea_white"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_cancel_route"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Annulla navigazione"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- HUD: profondita', coordinate, velocita' -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_hud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        app:cardBackgroundColor="#CC003366"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tv_hud_depth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profondita': -- m"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_hud_coords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lat: --, Lon: --"
                android:textColor="@color/sea_white"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_hud_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/sea_white"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bussola custom: top-right sotto la barra di ricerca.
         Visibile quando la mappa e' ruotata (follow mode o rotazione manuale).
         Tap: esce da follow mode e resetta il nord. La "N" rossa ruota con la mappa. -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_compass"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="88dp"
        android:layout_marginEnd="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#CC003366"
        app:cardCornerRadius="22dp"
        app:cardElevation="4dp">

        <TextView
            android:id="@+id/tv_compass"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="N"
            android:textColor="#FF4444"
            android:textSize="14sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- CENTRA: visibile solo quando followMode=false (camera libera).
         Nascosto con GONE quando la camera sta gia' seguendo la barca. -->
    <LinearLayout
        android:id="@+id/layout_centra"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="12dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_recentra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Centra sulla barca"
            android:src="@android:drawable/ic_menu_mylocation"
            app:backgroundTint="#CC003366"
            app:fabSize="mini"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CENTRA"
            android:textColor="@color/white"
            android:textSize="9sp"
            android:textStyle="bold"
            android:shadowColor="#000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2" />
    </LinearLayout>

</FrameLayout>
