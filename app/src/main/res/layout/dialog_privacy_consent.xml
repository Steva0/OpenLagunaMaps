<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_logo_nautical"
            app:tint="@color/marine_blue"
            android:contentDescription="@string/logo_desc" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/privacy_welcome"
            android:textAppearance="@style/TextAppearance.AppCompat.Headline"
            android:textColor="@color/marine_blue_dark"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/privacy_intro"
            android:textAppearance="@style/TextAppearance.AppCompat.Medium"
            android:textColor="@color/marine_blue"
            android:gravity="center"
            android:textStyle="italic" />

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:layout_marginTop="16dp"
            android:background="@color/marine_blue_light" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/privacy_body"
            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
            android:textColor="#444444"
            android:lineSpacingExtra="4sp"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_accept"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="@string/privacy_accept"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/marine_blue" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_read_more"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/privacy_read_more"
            android:textAllCaps="false"
            android:textColor="@color/marine_blue" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_exit"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/privacy_exit"
            android:textAllCaps="false"
            android:textColor="#888888"
            android:textSize="12sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>