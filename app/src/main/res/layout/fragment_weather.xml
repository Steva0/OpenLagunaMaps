<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sea_white">

    <!-- Stato: contenuto meteo caricato -->
    <ScrollView
        android:id="@+id/layout_weather_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Spazio per il tasto menu floating -->
            <View
                android:layout_width="match_parent"
                android:layout_height="56dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meteo Laguna"
                android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                android:textColor="@color/marine_blue_dark" />

            <TextView
                android:id="@+id/tv_weather_updated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textColor="@color/marine_blue"
                android:textSize="12sp" />

            <!-- Selettore giorno: "Oggi", "Domani", nomi giorno + frecce. In alto: la vista
                 sotto (card unica) cambia in base al giorno selezionato qui. -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <ImageButton
                        android:id="@+id/btn_day_prev"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Giorno precedente"
                        android:src="@android:drawable/ic_media_previous" />

                    <HorizontalScrollView
                        android:id="@+id/scroll_day_selector"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layout_day_selector"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <ImageButton
                        android:id="@+id/btn_day_next"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Giorno successivo"
                        android:src="@android:drawable/ic_media_next" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card unica: dati del giorno selezionato. Per "Oggi" mostra il valore live
                 ("adesso") più il min/max della giornata; per gli altri giorni solo la
                 previsione (non esiste un dato "live" per il futuro). -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_day_icon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:text="☀️"
                            android:textSize="56sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_day_temp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- °C"
                                android:textColor="#222222"
                                android:textSize="34sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_day_desc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#666666"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/tv_day_subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text=""
                                android:textColor="#999999"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="12dp"
                        android:background="#EEEEEE" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:text="💨"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tv_day_wind"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Vento: --"
                            android:textColor="#333333"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:text="🌧️"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tv_day_precip"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Precipitazioni: --"
                            android:textColor="#333333"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:text="🌊"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tv_day_waves"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Onde (mare): --"
                            android:textColor="#333333"
                            android:textSize="15sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Marea"
                        android:textColor="@color/marine_blue_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_tide_now"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Livello ora: --"
                        android:textColor="#333333"
                        android:textSize="15sp" />

                    <it.lagunav.openlagunamaps.ui.TideChartView
                        android:id="@+id/tide_chart"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Tocca o trascina sul grafico per vedere il livello alle varie ore"
                        android:textColor="#999999"
                        android:textSize="11sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btn_weather_refresh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Aggiorna"
                app:backgroundTint="@color/marine_blue" />

        </LinearLayout>
    </ScrollView>

    <!-- Stato: caricamento -->
    <LinearLayout
        android:id="@+id/layout_weather_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <!-- Spazio per il tasto menu floating (anche in caricamento) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="56dp" />

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Caricamento meteo…"
            android:textColor="@color/marine_blue_dark" />
    </LinearLayout>

    <!-- Stato: errore (nessuna connessione, o richiesta fallita) -->
    <LinearLayout
        android:id="@+id/layout_weather_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="visible">

        <!-- Spazio per il tasto menu floating (anche in errore) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="56dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/tv_weather_error_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Nessuna connessione a internet"
            android:textColor="@color/marine_blue_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Il meteo richiede una connessione internet attiva."
            android:textColor="@color/marine_blue" />

        <Button
            android:id="@+id/btn_weather_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Riprova"
            app:backgroundTint="@color/marine_blue" />
    </LinearLayout>

    <!-- Floating Menu Button -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btn_menu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:src="@drawable/ic_hamburger"
            android:contentDescription="@string/open_menu"
            app:tint="@color/black" />
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
