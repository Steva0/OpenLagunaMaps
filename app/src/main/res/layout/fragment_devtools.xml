<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Container dove viene embedded MapFragment con debugMode=true -->
    <FrameLayout
        android:id="@+id/map_container_dev"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Pannello debug sovrapposto in alto: spinner modalita' + stato simulatore -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#DD111111"
        app:cardCornerRadius="8dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <Spinner
                android:id="@+id/spinner_dev_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white" />

            <TextView
                android:id="@+id/tv_dev_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:text="Seleziona modalita'"
                android:textColor="#FF00FF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Joystick simulatore (fondo centro, visibile solo in modalita' sim) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_sim"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="#CC111111"
        app:cardCornerRadius="100dp"
        app:cardElevation="4dp">

        <it.lagunav.openlagunamaps.ui.JoystickView
            android:id="@+id/joystick"
            android:layout_width="160dp"
            android:layout_height="160dp" />
    </androidx.cardview.widget.CardView>

</FrameLayout>
