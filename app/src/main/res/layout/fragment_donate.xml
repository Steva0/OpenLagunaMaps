<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sea_white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Spazio per il tasto menu floating -->
            <View
                android:layout_width="match_parent"
                android:layout_height="56dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:contentPadding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_logo_nautical"
                        android:contentDescription="@string/logo_desc"
                        app:tint="@color/marine_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/donate_title"
                        android:textAppearance="@style/TextAppearance.AppCompat.Headline"
                        android:textColor="@color/marine_blue_dark"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/donate_subtitle"
                        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                        android:textColor="@color/marine_blue" />

                    <View
                        android:layout_width="60dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/marine_blue_light" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:lineSpacingExtra="4sp"
                        android:text="@string/donate_description"
                        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                        android:textColor="@color/marine_blue_dark" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_paypal"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="32dp"
                        android:text="@string/btn_paypal"
                        android:textAllCaps="false"
                        android:textSize="18sp"
                        app:cornerRadius="12dp"
                        app:icon="@android:drawable/ic_menu_send"
                        app:iconGravity="textStart"
                        app:backgroundTint="@color/marine_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/donate_coffee_text"
                        android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                        android:textColor="@color/marine_blue"
                        android:alpha="0.7" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/donate_thanks"
                android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                android:textColor="@color/marine_blue_dark"
                android:textStyle="italic" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Menu Button -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btn_menu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:src="@drawable/ic_hamburger"
            android:contentDescription="@string/open_menu"
            app:tint="@color/black" />
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
